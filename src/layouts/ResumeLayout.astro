---
import type { CollectionEntry } from "astro:content";
import QRCode from "qrcode";

interface Props {
  resume: CollectionEntry<"resume">["data"];
}

const { resume } = Astro.props;
const { basics, summary, experience, projects, education, skills } = resume;
const base = import.meta.env.BASE_URL;

const portfolioUrl = "https://cbridges1.github.io/portfolio/";
const qrCodeSvg = await QRCode.toString(portfolioUrl, {
  type: "svg",
  margin: 0,
  color: { dark: "#111827", light: "#ffffff" },
});
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{basics.name} — Resume</title>
		<meta name="description" content={summary} />
		<link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
	</head>
	<body>
		<div class="toolbar">
			<a href={base}>← Back to portfolio</a>
			<button type="button" onclick="window.print()">Download PDF</button>
		</div>

		<main class="resume">
			<header class="resume-header">
				<div class="resume-header-main">
					<h1>{basics.name}</h1>
					<p class="title">{basics.title}</p>
					<ul class="contact">
						<li>{basics.location}</li>
						<li>{basics.phone}</li>
						<li><a href={`mailto:${basics.email}`}>{basics.email}</a></li>
						{basics.links.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</div>
				<div class="resume-header-qr" set:html={qrCodeSvg} />
			</header>

			<section class="resume-section">
				<h2>Experience</h2>
				{experience.map((job) => (
					<article class="entry">
						<div class="entry-heading">
							<h3>
								{job.role} — {job.company}
								{job.location && <span class="location">, {job.location}</span>}
							</h3>
							<span class="dates">{job.startDate} — {job.endDate}</span>
						</div>
						<ul>
							{job.bullets.map((bullet) => <li>{bullet}</li>)}
						</ul>
					</article>
				))}
			</section>

			<section class="resume-section">
				<h2>Projects</h2>
				{projects.map((project) => (
					<article class="entry">
						<div class="entry-heading">
							<h3>
								{project.href ? <a href={project.href}>{project.name}</a> : project.name}
							</h3>
						</div>
						<ul>
							{project.bullets.map((bullet) => <li>{bullet}</li>)}
						</ul>
					</article>
				))}
			</section>

			<section class="resume-section">
				<h2>Education</h2>
				{education.map((school) => (
					<article class="entry">
						<div class="entry-heading">
							<h3>
								{school.school}
								{school.location && <span class="location">, {school.location}</span>}
							</h3>
							<span class="dates">{school.startDate} — {school.endDate}</span>
						</div>
						<p class="degree">
							{school.degree}
							{school.honors && ` · ${school.honors}`}
						</p>
					</article>
				))}
			</section>

			<section class="resume-section">
				<h2>Skills</h2>
				<div class="skills-grid">
					{skills.map((group) => (
						<div class="skill-group">
							<h3>{group.category}</h3>
							<p>{group.items.join(" · ")}</p>
						</div>
					))}
				</div>
			</section>
		</main>

		<style>
			:root {
				color-scheme: light;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				background: #e5e7eb;
				font-family: "Inter", system-ui, -apple-system, sans-serif;
				color: #111827;
			}

			.toolbar {
				position: sticky;
				top: 0;
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.75rem 1.5rem;
				background: #ffffff;
				color: #111827;
				border-bottom: 1px solid #e5e7eb;
			}

			.toolbar a {
				color: #111827;
				text-decoration: none;
				font-size: 0.9rem;
			}

			.toolbar button {
				background: #111827;
				color: #fff;
				border: 1px solid #374151;
				border-radius: 6px;
				padding: 0.5rem 1rem;
				font-size: 0.9rem;
				cursor: pointer;
			}

			.toolbar button:hover {
				background: #000;
			}

			/* Match the site header's own light/dark background so this page's
			   toolbar reads as the same "header" as every other page. */
			@media (prefers-color-scheme: dark) {
				.toolbar {
					background: #0f0f0f;
					color: #fff;
					border-bottom-color: #27272a;
				}

				.toolbar a {
					color: #fff;
				}
			}

			.resume {
				max-width: 8.5in;
				margin: 2rem auto;
				padding: 0.75in;
				background: #fff;
				box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
				line-height: 1.5;
			}

			.resume-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1rem;
				border-bottom: 2px solid #4b5563;
				padding-bottom: 0.75rem;
				margin-bottom: 1.5rem;
			}

			.resume-header-main {
				min-width: 0;
			}

			.resume-header-qr {
				flex-shrink: 0;
				width: 84px;
				height: 84px;
			}

			.resume-header-qr :global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}

			.resume-header h1 {
				margin: 0;
				font-size: 2rem;
			}

			.resume-header .title {
				margin: 0.25rem 0 0.75rem;
				color: #374151;
				font-size: 1.05rem;
			}

			.contact {
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 0 1rem;
				margin: 0;
				padding: 0;
				font-size: 0.9rem;
			}

			.contact a {
				color: #4b5563;
				text-decoration: underline;
			}

			.resume-section {
				margin-bottom: 1.5rem;
			}

			.resume-section h2 {
				font-size: 1.1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				border-bottom: 1px solid #d1d5db;
				padding-bottom: 0.25rem;
				margin-bottom: 0.75rem;
				color: #4b5563;
				break-after: avoid;
			}

			.entry {
				margin-bottom: 1rem;
				break-inside: avoid;
			}

			.entry-heading {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 0 0.75rem;
			}

			.entry-heading h3 {
				margin: 0;
				font-size: 1rem;
			}

			.entry-heading h3 a {
				color: inherit;
				text-decoration: none;
			}

			.entry-heading .location {
				font-weight: 400;
				color: #6b7280;
			}

			.entry-heading .dates {
				font-size: 0.85rem;
				color: #6b7280;
				white-space: nowrap;
			}

			.entry ul {
				margin: 0.4rem 0 0;
				padding-left: 1.1rem;
			}

			.entry li {
				margin-bottom: 0.2rem;
				font-size: 0.92rem;
			}

			.degree {
				margin: 0.3rem 0 0;
				font-size: 0.92rem;
				color: #374151;
			}

			.skills-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 0.6rem 1.5rem;
			}

			.skill-group h3 {
				margin: 0 0 0.15rem;
				font-size: 0.9rem;
			}

			.skill-group p {
				margin: 0;
				font-size: 0.88rem;
				color: #374151;
			}

			@media (max-width: 700px) {
				.resume {
					padding: 1.5rem;
					margin: 0;
				}

				.skills-grid {
					grid-template-columns: 1fr;
				}
			}

			@media print {
				/* Zero @page margin so Chrome/Firefox have no room left to draw their
				   own print header/footer (date, URL, page number) — the visual
				   margin is recreated below as padding on .resume instead, matching
				   the screen view's own 0.75in padding so print looks the same as web. */
				@page {
					size: letter;
					margin: 0;
				}

				.toolbar {
					display: none;
				}

				body {
					background: #fff;
				}

				.resume {
					margin: 0;
					padding: 0.75in;
					box-shadow: none;
					max-width: none;
					/* padding-top/bottom on a box that spans multiple printed pages is
					   only applied once (on the first/last fragment) by default, which
					   left continuation pages with no top margin. `clone` re-applies the
					   full padding on every page fragment instead. */
					-webkit-box-decoration-break: clone;
					box-decoration-break: clone;
				}

				.entry,
				.skill-group {
					break-inside: avoid;
				}
			}
		</style>
	</body>
</html>
