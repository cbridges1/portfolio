---
import Default from "@astrojs/starlight/components/Footer.astro";
import PwaToast from "./PwaToast.astro";

const columns = [
	{
		title: "Portfolio",
		links: [
			{ label: "About", href: "/portfolio/about/" },
			{ label: "Skills", href: "/portfolio/skills/" },
			{ label: "Resume", href: "/portfolio/resume/" },
			{ label: "QR Code", href: "/portfolio/qr/" },
		],
	},
	{
		title: "Projects",
		links: [
			{ label: "Acsys", href: "/portfolio/projects/acsys/" },
			{ label: "React Native AdMob", href: "/portfolio/projects/react-native-admob/" },
			{ label: "Hyve", href: "/portfolio/projects/hyve/" },
			{ label: "Portainer CLI", href: "/portfolio/projects/portainer-cli/" },
		],
	},
	{
		title: "Connect",
		links: [
			{ label: "GitHub", href: "https://github.com/cbridges1" },
			{ label: "Guidewire Software", href: "https://www.guidewire.com" },
		],
	},
];

const year = new Date().getFullYear();
---

<div class="site-footer">
	<div class="site-footer-columns">
		{
			columns.map((column) => (
				<div class="site-footer-column">
					<h2>{column.title}</h2>
					<ul>
						{column.links.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
	<p class="site-footer-copyright">Copyright © {year} Jalen Bridges</p>
</div>

<Default {...Astro.props}><slot /></Default>
<PwaToast />

<style>
	.site-footer {
		margin-top: 2rem;
		padding-top: 2rem;
		border-top: 1px solid var(--sl-color-hairline);
	}

	.site-footer-columns {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.site-footer-column h2 {
		font-size: var(--sl-text-sm);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-2);
		margin: 0 0 0.5rem;
		border: none;
		padding: 0;
	}

	.site-footer-column ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.site-footer-column a {
		color: var(--sl-color-gray-3);
		text-decoration: none;
		font-size: var(--sl-text-sm);
	}

	.site-footer-column a:hover {
		color: var(--sl-color-white);
	}

	.site-footer-copyright {
		margin: 1.5rem 0 0;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-4);
	}

	@media (max-width: 50rem) {
		.site-footer-columns {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 30rem) {
		.site-footer-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
