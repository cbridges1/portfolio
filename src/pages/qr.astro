---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import QRCode from "qrcode";

const base = import.meta.env.BASE_URL;
const portfolioUrl = "https://cbridges1.github.io/portfolio/";

const qrCodeSvg = await QRCode.toString(portfolioUrl, {
	type: "svg",
	margin: 0,
	color: { dark: "#111111", light: "#00000000" },
});
---

<StarlightPage
	hasSidebar={false}
	frontmatter={{
		title: "QR Code",
		description: "Scan to visit the Jalen Bridges portfolio site.",
		template: "splash",
	}}
>
	<div class="qr-wrap">
		<div class="qr-card" set:html={qrCodeSvg} />
		<p class="qr-caption">Scan to visit</p>
		<a class="qr-url" href={portfolioUrl}>cbridges1.github.io/portfolio</a>
	</div>
</StarlightPage>

<style>
	.qr-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-block: 2rem 3rem;
		text-align: center;
	}

	.qr-card {
		width: min(320px, 70vw);
		height: min(320px, 70vw);
		padding: 1.5rem;
		background: #ffffff;
		border-radius: 1rem;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
	}

	.qr-card :global(svg) {
		display: block;
		width: 100%;
		height: 100%;
	}

	.qr-caption {
		margin: 0;
		font-size: var(--sl-text-lg);
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.qr-url {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		text-decoration: none;
	}

	.qr-url:hover {
		color: var(--sl-color-white);
		text-decoration: underline;
	}
</style>
