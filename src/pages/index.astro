---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Card, CardGrid, LinkCard } from "@astrojs/starlight/components";

const base = import.meta.env.BASE_URL;
---

<StarlightPage
	hasSidebar={false}
	frontmatter={{
		title: "Home",
		description:
			"Software engineer at Guidewire Software. Builder of open-source tools, CLIs, and developer infrastructure.",
		template: "splash",
		hero: {
			title: "Jalen Bridges",
			tagline: "Software engineer at Guidewire Software. Builder of open-source tools, CLIs, and developer infrastructure.",
			actions: [
				{ text: "View Portfolio", link: `${base}about/`, icon: "right-arrow", variant: "primary" },
				{ text: "Resume", link: `${base}resume/`, icon: "document" },
				{ text: "GitHub", link: "https://github.com/cbridges1", icon: "external" },
			],
		},
	}}
>
	<h2>Featured Projects</h2>
	<CardGrid>
		<LinkCard
			title="Acsys — Headless CMS"
			href={`${base}projects/acsys/`}
			description="Easy-install headless CMS backed by SQLite, MySQL, or Cloud Firestore. 52 GitHub stars."
		/>
		<LinkCard
			title="Hyve — GitOps CLI"
			href={`${base}projects/hyve/`}
			description="Go-based developer infrastructure tooling with a companion CLI for Kubernetes cluster lifecycle management."
		/>
		<LinkCard
			title="Portainer CLI"
			href={`${base}projects/portainer-cli/`}
			description="Command-line interface for managing Portainer container environments."
		/>
		<LinkCard
			title="React Native AdMob"
			href={`${base}projects/react-native-admob/`}
			description="Native ad rendering library for React Native using Android native views and Google AdMob."
		/>
	</CardGrid>

	<h2>Tech Stack</h2>
	<CardGrid cols={3}>
		<Card title="Languages" icon="seti:javascript">
			JavaScript · TypeScript · Go · Java · Shell
		</Card>
		<Card title="Frameworks" icon="puzzle">
			React · React Native · Node.js · Express · Next.js
		</Card>
		<Card title="Infrastructure" icon="cloud">
			Firebase · GCP · Docker · Portainer · Nginx
		</Card>
	</CardGrid>

	<h2>Currently</h2>
	<p>
		Software engineer at <strong>Guidewire Software</strong>, building and maintaining
		enterprise software for the insurance industry.
	</p>
	<p>
		Open-source contributor — see <a href="https://github.com/cbridges1">github.com/cbridges1</a> for
		active projects, or view the full <a href={`${base}resume/`}>resume</a>.
	</p>
</StarlightPage>
